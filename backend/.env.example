# Example DATABASE_URL for Supabase (Postgres)
# Create a free Supabase project and copy the connection string here.
# Format: postgresql://<user>:<password>@<host>:5432/<database>
DATABASE_URL="postgresql://postgres:password@db.yoursupabase.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.yoursupabase.supabase.co:5432/postgres"

# JWT secret used by the backend (keep private)
JWT_SECRET=your_jwt_secret_here

# Supabase service role key (use for server-side admin operations). Keep this secret.
SUPABASE_URL=https://joqmuusjfunvmuzihjsz.supabase.co
# Replace with the service role key (server-only). Keep secret.
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe keys
STRIPE_SECRET=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
# This is the webhook signing secret from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Signed URL controls for paid/free internal books
BOOKS_STORAGE_BUCKET=books
# 60-3600 recommended. Default in code is 900 seconds.
BOOK_SIGNED_URL_TTL_SECONDS=900
# MTN Mobile Money API (Sandbox)
MTN_API_KEY=your_mtn_api_key
MTN_API_SECRET=your_mtn_api_secret
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_CALLBACK_URL=https://yourdomain.com/payment/mobile-money/webhook

# Airtel Money API (for Uganda)
# Get from Airtel Africa Developer Portal
AIRTEL_API_KEY=your_airtel_api_key
AIRTEL_API_SECRET=your_airtel_api_secret
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CALLBACK_URL=https://yourdomain.com/payment/mobile-money/webhook
